14:["$","p",null,{"style":{"fontSize":15,"color":"var(--muted)","lineHeight":1.7,"fontFamily":"DM Sans, sans-serif"},"children":["Zonder zonnepanelen is de batterij afhankelijk van laden op daluren (goedkope stroom 's nachts). In dat geval bepaalt uw dagverbruik de gewenste capaciteit — zie onze pagina ",["$","$L2",null,{"href":"/thuisbatterij-zonder-zonnepanelen","style":{"color":"var(--blue-mid)"},"children":"thuisbatterij zonder zonnepanelen"}],"."]}]
