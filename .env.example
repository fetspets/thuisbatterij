# ============================================
# ThuisbatterijBelgie.be — Omgevingsvariabelen
# ============================================
# Kopieer dit bestand naar .env.local en vul uw waarden in.
# .env.local wordt NOOIT naar GitHub gepusht.

# --------------------------------------------
# LAAG 1: E-mailnotificaties via Resend
# --------------------------------------------
# Maak een gratis account op https://resend.com
# Gratis tier: 3.000 e-mails/maand
# Stap 1: Registreer op resend.com
# Stap 2: Maak een API key aan onder "API Keys"
# Stap 3: Plak de key hieronder

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Het e-mailadres waar nieuwe leads naartoe gestuurd worden (uw eigen adres)
LEAD_EMAIL=uw@emailadres.be

# --------------------------------------------
# LAAG 2: Webhook (Zapier, Make.com, n8n, enz.)
# --------------------------------------------
# Optioneel: stuur leads door naar een externe service
#
# Via Zapier:
#   1. Ga naar zapier.com → Create Zap
#   2. Trigger: "Webhooks by Zapier" → Catch Hook
#   3. Kopieer de webhook URL en plak hieronder
#   4. Actie: Google Sheets (leads bijhouden), Gmail, Slack, ...
#
# Via Make.com (gratis tier beschikbaar):
#   1. Ga naar make.com → Create Scenario
#   2. Module: "Webhooks" → Custom Webhook
#   3. Kopieer URL en plak hieronder

WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxxxx/xxxxxxx

# --------------------------------------------
# VERCEL DEPLOYMENT
# --------------------------------------------
# Voeg deze variabelen toe in uw Vercel dashboard:
# Project Settings → Environment Variables
# Vergeet niet opnieuw te deployen na het toevoegen.
